{
  "name": "orison",
  "version": "2.0.0",
  "description": "A static site generator built on top of lit-html.",
  "keywords": [
    "Static site generation",
    "lit-html",
    "web development",
    "progressive web app",
    "single page application"
  ],
  "homepage": "https://orison.alexlockhart.me",
  "repository": {
    "type": "git",
    "url": "https://github.com/megazear7/orison"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "main": "bin/orison.js",
  "exports": {
    ".": "./bin/orison.js"
  },
  "dependencies": {
    "@lit-labs/ssr": "4.1.0",
    "express": "^5.2.1",
    "jiti": "^2.4.2",
    "lit": "^3.3.1",
    "markdown-it": "^14.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/express": "^5.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.1",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.27.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "rollup": "^4.41.1",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "start": "concurrently \"npm run orison:watch\" \"npm run docs:serve\"",
    "orison:watch": "node -e \"require('node:fs').rmSync('bin', { force: true, recursive: true })\" && rollup -c -w",
    "orison:build": "node -e \"require('node:fs').rmSync('bin', { force: true, recursive: true })\" && rollup -c",
    "docs:serve": "node ./bin/cli.js serve ./docs",
    "docs:build": "node ./bin/cli.js build ./docs",
    "lint": "prettier package.json eslint.config.js rollup.config.mjs tsconfig.json src --check && eslint src",
    "fix": "prettier package.json eslint.config.js rollup.config.mjs tsconfig.json src --write && eslint src --fix"
  },
  "bin": {
    "orison": "./bin/cli.js"
  },
  "author": "Alex Lockhart",
  "license": "ISC"
}
