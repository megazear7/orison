{
  "name": "orison",
  "version": "2.0.0",
  "description": "A static site generator built on top of lit-html.",
  "keywords": [
    "Static site generation",
    "lit-html",
    "web development",
    "progressive web app",
    "single page application"
  ],
  "homepage": "https://orison.alexlockhart.me",
  "repository": {
    "type": "git",
    "url": "https://github.com/megazear7/orison"
  },
  "engines": {
    "node": ">=10.15.3"
  },
  "main": "bin/orison.js",
  "dependencies": {
    "@lit-labs/ssr": "4.1.0",
    "markdown-it": "^14.2.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
  },
  "scripts": {
    "start": "npm run orison:watch && npm run docs:serve",
    "orison:watch": "",
    "orison:build": "",
    "docs:serve": "cd docs && orison serve",
    "docs:build": "cd docs && orison build",
    "lint": "prettier src --check && eslint src",
    "fix": "prettier src --write && eslint src --fix"
  },
  "bin": {
    "orison": "./bin/cli.js"
  },
